# Sugar Agent 环境变量配置
# 复制此文件为 .env 并填入真实的 API Keys

# ===== LLM 配置 =====
# DeepSeek API Key (推荐，便宜且效果好)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# 千问 API Key (备用)
DASHSCOPE_API_KEY=sk-your-qwen-api-key

# Anthropic API Key (可选，效果最好)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ===== 天气 API =====
# 心知天气 (https://www.seniverse.com/)
SENIVERSE_API_KEY=your-seniverse-api-key

# 或 OpenWeatherMap (https://openweathermap.org/)
OPENWEATHER_API_KEY=your-openweather-api-key

# ===== 微信桥接 =====
# 外部桥接进程的 URL
BRIDGE_BASE_URL=http://localhost:9001
# 桥接通信密钥
BRIDGE_API_KEY=your-bridge-api-key
# Webhook 验证 token
WEBHOOK_SECRET_TOKEN=your-webhook-secret

# ===== 管理后台 =====
# 管理后台登录密码 (用户名: admin)
ADMIN_PASSWORD=your-admin-password

# ===== 运行环境 =====
# development | production
SUGAR_ENV=development
